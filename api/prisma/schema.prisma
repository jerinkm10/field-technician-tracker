generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
}

enum TechnicianStatus {
  AVAILABLE
  ON_JOB
  OFFLINE
}

enum JobStatus {
  PENDING
  ASSIGNED
  STARTED
  COMPLETED
  CANCELLED
}

enum AttachmentType {
  PHOTO
  SIGNATURE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum InvoiceType {
  PROFORMA
  TAX
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ProductServiceType {
  PRODUCT
  SERVICE
}

enum ProductServiceStatus {
  ACTIVE
  INACTIVE
}

enum OutstandingStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum AmcBillingPeriod {
  QUARTERLY
  HALF_YEARLY
  YEARLY
}

enum AmcStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  DEMO_SCHEDULED
  CONVERTED
  LOST
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  role       Role
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  technician Technician?
  leadNotes  LeadNote[]
  leadStatusHistory LeadStatusHistory[]

  @@index([role])
}

model Technician {
  id               String           @id @default(cuid())
  userId           String           @unique
  phone            String           @unique
  status           TechnicianStatus @default(OFFLINE)
  currentLatitude  Float?
  currentLongitude Float?
  lastSeenAt       DateTime?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs             Job[]
  jobVisits        JobVisit[]
  locationLogs     LocationLog[]

  @@index([status])
}

model Customer {
  id              String          @id @default(cuid())
  name            String
  phone           String
  email           String?
  gstin           String?         @unique
  address         String
  billingAddress  String?
  shippingAddress String?
  placeOfSupply   String?
  latitude        Float?
  longitude       Float?
  status          CustomerStatus  @default(ACTIVE)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  jobs            Job[]
  invoices        Invoice[]
  quotations      Quotation[]
  outstandings    Outstanding[]
  amcs            Amc[]

  @@index([name])
  @@index([phone])
  @@index([gstin])
  @@index([status])
}

model Job {
  id            String          @id @default(cuid())
  jobNumber     String          @unique
  title         String
  description   String
  customerId    String
  technicianId  String
  status        JobStatus       @default(PENDING)
  scheduledDate DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  customer      Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  technician    Technician      @relation(fields: [technicianId], references: [id], onDelete: Restrict)
  visits        JobVisit[]
  locationLogs  LocationLog[]
  attachments   JobAttachment[]

  @@index([customerId])
  @@index([technicianId])
  @@index([status])
  @@index([scheduledDate])
}

model JobVisit {
  id               String     @id @default(cuid())
  jobId            String
  technicianId     String
  checkInAt        DateTime
  checkOutAt       DateTime?
  timeSpentMinutes Int?
  startLatitude    Float
  startLongitude   Float
  endLatitude      Float?
  endLongitude     Float?
  job              Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  technician       Technician @relation(fields: [technicianId], references: [id], onDelete: Restrict)

  @@index([jobId])
  @@index([technicianId])
  @@index([checkInAt])
}

model LocationLog {
  id           String     @id @default(cuid())
  technicianId String
  jobId        String?
  latitude     Float
  longitude    Float
  accuracy     Float
  speed        Float
  batteryLevel Int?
  recordedAt   DateTime   @default(now())
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  job          Job?       @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([technicianId])
  @@index([jobId])
  @@index([recordedAt])
}

model JobAttachment {
  id        String         @id @default(cuid())
  jobId     String
  type      AttachmentType
  fileUrl   String
  createdAt DateTime       @default(now())
  job       Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([type])
}

/// Backend master for branches. The frontend shows this entity as "Branch"
/// to preserve business terminology without breaking existing APIs.
model Supplier {
  id            String         @id @default(cuid())
  supplierName  String
  phone         String
  email         String
  gstin         String         @unique
  address       String
  bankName      String
  accountNumber String
  ifscCode      String
  status        SupplierStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  invoices      Invoice[]
  quotations    Quotation[]
  amcs          Amc[]
  leads         Lead[]

  @@index([supplierName])
  @@index([phone])
  @@index([gstin])
  @@index([status])
}

model ProductService {
  id            String               @id @default(cuid())
  name          String
  type          ProductServiceType
  description   String
  hsnSacCode    String
  unit          String
  defaultRate   Float
  taxPercentage Float
  status        ProductServiceStatus @default(ACTIVE)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  leads         Lead[]

  @@index([name])
  @@index([type])
  @@index([status])
  @@index([hsnSacCode])
}

model Company {
  id                  String        @id @default(cuid())
  companyName         String
  phone               String
  email               String
  gstin               String
  address             String
  city                String
  state               String
  pinCode             String
  country             String
  bankName            String
  accountNumber       String
  ifscCode            String
  logoAttachment      String?
  signatureAttachment String?
  sealAttachment      String?
  status              CompanyStatus @default(ACTIVE)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status])
}

model Invoice {
  id                 String          @id @default(cuid())
  invoiceType        InvoiceType
  invoiceNumber      String          @unique
  invoiceDate        DateTime
  supplierId         String
  customerId         String
  customerName       String
  customerAddress    String
  customerGstin      String
  placeOfSupply      String
  notes              String?
  termsAndConditions String?
  totalBeforeTax     Float
  totalTaxAmount     Float
  roundedOff         Float
  totalAmount        Float
  amountDue          Float
  status             InvoiceStatus   @default(DRAFT)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  supplier           Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  customer           Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lineItems          InvoiceLineItem[]
  outstanding        Outstanding?
  amcInvoices        AmcInvoice[]

  @@index([invoiceType])
  @@index([invoiceDate])
  @@index([supplierId])
  @@index([customerId])
  @@index([status])
}

model Outstanding {
  id                String            @id @default(cuid())
  invoiceId         String            @unique
  invoiceType       InvoiceType
  invoiceNumber     String
  customerId        String
  customerName      String
  invoiceDate       DateTime
  dueDate           DateTime
  totalAmount       Float
  paidAmount        Float             @default(0)
  creditAmount      Float             @default(0)
  outstandingAmount Float
  status            OutstandingStatus @default(PENDING)
  note              String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  invoice           Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  customer          Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([invoiceType])
  @@index([invoiceNumber])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([status])
}

/// AMC contract model. Kept as `Amc` in Prisma/client code to avoid breaking
/// existing backend services that already use this generated type.
model Amc {
  id                  String           @id @default(cuid())
  amcNumber           String           @unique
  customerId          String
  customerName        String
  branchId            String
  startDate           DateTime
  endDate             DateTime
  durationMonths      Int
  billingPeriod       AmcBillingPeriod
  billingPeriodMonths Int
  contractAmount      Float
  taxPercentage       Float
  status              AmcStatus        @default(ACTIVE)
  lastPaidDate        DateTime?
  nextBillingDate     DateTime?
  note                String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  customer            Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  branch              Supplier         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  invoices            AmcInvoice[]

  @@index([amcNumber])
  @@index([customerId])
  @@index([branchId])
  @@index([startDate])
  @@index([endDate])
  @@index([billingPeriod])
  @@index([status])
  @@index([nextBillingDate])
}

/// AMC invoice history model. Kept as `AmcInvoice` in Prisma/client code to
/// avoid breaking existing backend services that already use this generated type.
model AmcInvoice {
  id                 String   @id @default(cuid())
  amcId              String
  invoiceId          String   @unique
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  createdAt          DateTime @default(now())
  amc                Amc      @relation(fields: [amcId], references: [id], onDelete: Cascade)
  invoice            Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([amcId])
  @@index([billingPeriodStart])
  @@index([billingPeriodEnd])
}

model InvoiceLineItem {
  id                 String  @id @default(cuid())
  invoiceId          String
  productServiceName String
  description        String
  hsnSac             String
  quantity           Float
  unitPrice          Float
  cgstAmount         Float
  cgstPercentage     Float
  sgstAmount         Float
  sgstPercentage     Float
  lineAmount         Float
  invoice            Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Quotation {
  id                 String           @id @default(cuid())
  quotationNumber    String           @unique
  quotationDate      DateTime
  validUntil         DateTime
  supplierId         String
  customerId         String
  customerName       String
  customerAddress    String
  customerGstin      String
  placeOfSupply      String
  notes              String?
  termsAndConditions String?
  totalBeforeTax     Float
  totalTaxAmount     Float
  roundedOff         Float
  totalAmount        Float
  status             QuotationStatus  @default(DRAFT)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  supplier           Supplier         @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  customer           Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  lineItems          QuotationLineItem[]

  @@index([quotationDate])
  @@index([validUntil])
  @@index([supplierId])
  @@index([customerId])
  @@index([status])
}

model QuotationLineItem {
  id                 String    @id @default(cuid())
  quotationId        String
  productServiceName String
  description        String
  hsnSac             String
  quantity           Float
  unitPrice          Float
  cgstAmount         Float
  cgstPercentage     Float
  sgstAmount         Float
  sgstPercentage     Float
  lineAmount         Float
  quotation          Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model InvoiceInputField {
  id          String   @id @default(cuid())
  section     String
  fieldKey    String   @unique
  label       String
  inputType   String
  placeholder String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section])
  @@index([isActive])
}

model Lead {
  id                         String            @id @default(cuid())
  leadName                   String
  customerName               String
  phone                      String
  email                      String?
  location                   String
  branchId                   String
  branchName                 String
  source                     String
  interestedProductServiceId String
  status                     LeadStatus        @default(NEW)
  note                       String?
  nextFollowUpDate           DateTime?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  branch                     Supplier          @relation(fields: [branchId], references: [id], onDelete: Restrict)
  interestedProductService   ProductService    @relation(fields: [interestedProductServiceId], references: [id], onDelete: Restrict)
  notes                      LeadNote[]
  statusHistory              LeadStatusHistory[]

  @@index([leadName])
  @@index([customerName])
  @@index([phone])
  @@index([email])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([nextFollowUpDate])
}

model LeadNote {
  id            String   @id @default(cuid())
  leadId         String
  note           String
  createdById    String?
  createdByName  String
  createdAt      DateTime @default(now())
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy      User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([createdAt])
}

model LeadStatusHistory {
  id               String     @id @default(cuid())
  leadId           String
  status           LeadStatus
  note             String?
  nextFollowUpDate DateTime?
  changedById      String?
  changedByName    String
  createdAt        DateTime   @default(now())
  lead             Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changedBy        User?      @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([status])
  @@index([createdAt])
}
